# ══ Environment & Secrets (ALL subdirectories) ════════
# Root
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging

# Sub-module envs (any depth)
**/.env
**/.env.local
**/.env.*.local
**/.env.development
**/.env.production
**/.env.staging

# Secret keys / certs
*.pem
*.key
*.cert
*.p12
*.pfx

# ══ Next.js (port 3000) ══════════════════════════════
.next/
out/
next-env.d.ts

# ══ Vite / React (Client Side, port 8080) ════════════
Client Side/ai-skill-analyzer-main/dist/
Client Side/ai-skill-analyzer-main/node_modules/
Client Side/ai-skill-analyzer-main/.next/

# ══ Node general ══════════════════════════════════════
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js
bun.lockb
package-lock.json

